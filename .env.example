# Local app runtime
MODEL_PROVIDER=openrouter
OPENROUTER_API_KEY=***
OPENROUTER_MODEL=openai/gpt-4.1-mini
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=***
TOKEN_PEPPER=***
# Optional local overrides when you want the app to use provisioned AWS tables
SESSION_TABLE_NAME=
TOKEN_TABLE_NAME=
SESSION_TTL_HOURS=168
# Optional only when testing origin protection locally behind a proxy
ORIGIN_VERIFY_HEADER=
ORIGIN_VERIFY_TOKEN=

# CDK deployment synth-time config
# Required: create a Secrets Manager secret with SESSION_SECRET and TOKEN_PEPPER,
# plus OPENROUTER_API_KEY if using MODEL_PROVIDER=openrouter.
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=us-east-1
APP_CONFIG_SECRET_NAME=intera...time
DEPLOYMENT_STAGE=dev
LAMBDA_MEMORY_SIZE=1536
LAMBDA_TIMEOUT_SECONDS=30
# Optional explicit table names / hardening toggles
SESSION_TABLE_NAME=
TOKEN_TABLE_NAME=
SESSION_TTL_HOURS=168
ENABLE_WAF=true
ENABLE_ORIGIN_PROTECTION=true

# Optional CloudFront custom domain
CUSTOM_DOMAIN_NAME=
HOSTED_ZONE_NAME=
ACM_CERTIFICATE_ARN=
