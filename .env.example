# Cloud inference
MODEL_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.7-sonnet
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=

# App
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-me
TOKEN_PEPPER=replace-me

# Persistence
# Use dynamodb in AWS Lambda. The file adapter is only for local development/scripts.
PERSISTENCE_ADAPTER=file
LOCAL_DATA_FILE=.data/interactive-business-card-store.json
DYNAMODB_TABLE_NAME=interactive-business-card
DYNAMODB_REGION=us-east-1
