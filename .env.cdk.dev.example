# CDK synth/deploy environment (dev)
# Copy to .env.cdk.dev and fill values.

AWS_PROFILE=personal
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1
APP_CONFIG_SECRET_NAME=interactive-business-card/runtime-dev
DEPLOYMENT_STAGE=dev

# Inference provider config used at deploy/runtime
MODEL_PROVIDER=openrouter
OPENROUTER_MODEL=openai/gpt-4.1-mini
# Optional for MODEL_PROVIDER=bedrock
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=

# Optional sizing
LAMBDA_MEMORY_SIZE=1536
LAMBDA_TIMEOUT_SECONDS=30

# Optional table naming and retention settings
SESSION_TABLE_NAME=
TOKEN_TABLE_NAME=
SESSION_TTL_HOURS=168

# Edge hardening
ENABLE_WAF=true
ENABLE_ORIGIN_PROTECTION=true

# Optional CloudFront custom domain
CUSTOM_DOMAIN_NAME=
HOSTED_ZONE_NAME=
ACM_CERTIFICATE_ARN=
